# Copy to .env.local and paste your real key (local dev only; never commit .env.local).
# ARCADE ORACLE uses the Groq API (free tier). Key from console.groq.com.
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Global high-score leaderboard uses Upstash Redis (free tier). Create a DB at
# upstash.com (or via the Vercel Marketplace) and paste the REST credentials.
# Without these the leaderboard simply shows "OFFLINE" and games still play.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
