# Copy to .env.local and paste your real key (local dev only; never commit .env.local).
# ARCADE ORACLE uses the Groq API (free tier). Key from console.groq.com.
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Global high-score leaderboard uses Upstash Redis (free tier).
# Easiest: add the "Upstash for Redis" integration in the Vercel dashboard
# (Storage tab) and run `vercel env pull .env.local` — it injects KV_REST_API_*.
# Manual setup: create a DB at upstash.com and set EITHER pair below (the API
# reads KV_REST_API_* first, then falls back to UPSTASH_REDIS_REST_*).
# Without these the leaderboard simply shows "OFFLINE" and games still play.
KV_REST_API_URL=https://your-db.upstash.io
KV_REST_API_TOKEN=your-upstash-rest-token
